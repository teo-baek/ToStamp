# ToStamp Backend — Environment Variables
# Copy this file to .env and fill in your values.

# App
DEBUG=true
APP_VERSION=0.1.0

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://tostamp:tostamp@localhost:5432/tostamp

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# QR Token TTL (seconds)
QR_TOKEN_TTL_SECONDS=180

# Firebase (optional for local dev)
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# GCP
# GCP_PROJECT_ID=your-gcp-project-id
